{
   "semi": false,
   "arrowParens": "always",
   "bracketSameLine": false,
   "bracketSpacing": true,
   "endOfLine": "lf",
   "singleQuote": false,
   "objectWrap": "preserve",
   "printWidth": 80,
   "useTabs": false,
   "trailingComma": "es5",
   "tabWidth": 3,
   "singleAttributePerLine": true,
   "vueIndentScriptAndStyle": false,
   "experimentalTernaries": false,
   "overrides": [
      {
         "files": ["package.json", "tsconfig.json"],
         "options": {
            "tabWidth": 2
         }
      }
   ]
}
